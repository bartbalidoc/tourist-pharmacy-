# Tourist Pharmacy — review server config.
# Copy to ".env" on the droplet and fill in real values. NEVER commit the real .env.

# REQUIRED — the shared password your reviewers type on the login page.
SITE_PASSWORD=change-this-to-something-only-your-team-knows

# Cookie signing secret. Set a long random string (e.g. `openssl rand -hex 32`).
SESSION_SECRET=

# Optional — enables AI structuring of each feedback note into a clear, actionable issue.
# Without it, feedback is still saved verbatim. Key is in the simple Asana board.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Set to 1 to auto git-commit + push each feedback file (needs git auth configured on the box).
# Leave empty to just write files into feedback/ (pull them with scp / git pull manually).
FEEDBACK_GIT=

# Port the Node server listens on (nginx proxies to this). 8080 is fine.
PORT=8080
