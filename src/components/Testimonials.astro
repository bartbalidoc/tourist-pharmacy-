---
import Stars from './Stars.astro';
import { TESTIMONIALS, TESTIMONIALS_ARE_SAMPLES } from '../lib/site';
const avg = (TESTIMONIALS.reduce((s, t) => s + t.rating, 0) / TESTIMONIALS.length).toFixed(1);
// Never publish unverified/sample reviews (trust + compliance). Section only renders once
// TESTIMONIALS_ARE_SAMPLES is set false in site.ts (i.e. real, verifiable reviews are in).
---
{!TESTIMONIALS_ARE_SAMPLES && (
<section class="section reviews">
  <div class="container">
    <header class="reviews__head">
      <p class="eyebrow">What travellers say</p>
      <h2>Trusted by tourists &amp; expats across Bali</h2>
      <div class="reviews__avg">
        <Stars rating={Number(avg)} size="1.15rem" />
        <span><strong>{avg}</strong> average · real people, real prescriptions</span>
      </div>
      {TESTIMONIALS_ARE_SAMPLES && (
        <!-- TODO: replace TESTIMONIALS in src/lib/site.ts with real, verifiable reviews before launch -->
        <p class="reviews__note">Sample testimonials shown — replace with verified reviews before launch.</p>
      )}
    </header>
    <div class="reviews__grid">
      {TESTIMONIALS.map((t) => (
        <figure class="review">
          <Stars rating={t.rating} />
          <blockquote>“{t.quote}”</blockquote>
          <figcaption><strong>{t.name}</strong><span>{t.location}</span></figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
)}
<style>
  .reviews { background: var(--c-paper-2); }
  .reviews__head { text-align: center; max-width: 46ch; margin: 0 auto var(--sp-6); }
  .reviews__head .eyebrow { justify-content: center; }
  .reviews__head h2 { font-size: var(--fs-700); margin-top: var(--sp-2); }
  .reviews__avg { display: inline-flex; align-items: center; gap: 0.6rem; margin-top: var(--sp-3); color: var(--c-ink-soft); font-size: var(--fs-350); }
  .reviews__avg strong { color: var(--c-ink); }
  .reviews__note { font-size: var(--fs-300); color: var(--c-ink-faint); font-style: italic; margin-top: var(--sp-2); }
  .reviews__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--sp-5); }
  .review {
    margin: 0; background: var(--c-surface); border: 1px solid var(--c-cream-line);
    border-radius: var(--radius-lg); padding: var(--sp-5); box-shadow: var(--shadow-sm);
    display: grid; gap: var(--sp-3);
  }
  .review blockquote { margin: 0; color: var(--c-ink); line-height: 1.55; }
  .review figcaption strong { display: block; color: var(--c-ink); }
  .review figcaption span { font-size: var(--fs-300); color: var(--c-ink-faint); }
  @media (max-width: 820px) { .reviews__grid { grid-template-columns: 1fr; } }
</style>
