---
import Icon from './Icon.astro';
import SearchBar from './SearchBar.astro';
import { SITE, WHATSAPP, NAV_LINKS, waLink } from '../lib/site';
const path = Astro.url.pathname;
const isActive = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));
---

<header class="nav">
  <div class="container nav__inner">
    <a href="/" class="nav__brand" aria-label={`${SITE.name} — home`}>
      <img class="nav__mark" src="/logo-mark.svg" alt="" width="40" height="40" />
      <span class="nav__name">Tourist<span>Pharmacy</span></span>
    </a>

    <div class="nav__search"><SearchBar /></div>

    <button class="nav__toggle" aria-expanded="false" aria-controls="nav-menu" aria-label="Open menu">
      <Icon name="menu" size="1.4rem" />
    </button>

    <nav id="nav-menu" class="nav__menu" aria-label="Primary">
      <div class="nav__search nav__search--mobile"><SearchBar /></div>
      <ul class="nav__links">
        {NAV_LINKS.map((l) => (
          <li>
            <a href={l.href} class:list={['nav__link', { 'is-active': isActive(l.href) }]}
               aria-current={isActive(l.href) ? 'page' : undefined}>{l.label}</a>
          </li>
        ))}
      </ul>
      <a class="nav__upload" href="/prescription">
        <Icon name="upload" size="1.05rem" /> Upload prescription
      </a>
      <a class="btn btn--whatsapp btn--sm nav__cta" href={waLink()} target="_blank" rel="noopener"
         aria-label={`Message us on WhatsApp at ${WHATSAPP.display}`}>
        <Icon name="whatsapp" /> WhatsApp
      </a>
    </nav>
  </div>
</header>

<style>
  .nav {
    position: sticky; top: 0; z-index: 50;
    background: color-mix(in srgb, var(--c-paper) 88%, transparent);
    backdrop-filter: saturate(150%) blur(12px);
    border-bottom: 1px solid var(--c-cream-line);
  }
  .nav__inner { display: flex; align-items: center; gap: var(--sp-4); min-height: 72px; }
  .nav__brand {
    display: inline-flex; align-items: center; gap: 0.6rem; text-decoration: none; flex: none;
    font-family: var(--font-display); font-weight: 700; font-size: 1.3rem; color: var(--c-ink);
    letter-spacing: var(--tracking-tight);
  }
  .nav__mark { width: 40px; height: 40px; flex: none; display: block; }
  .nav__name span { color: var(--c-terracotta); }

  .nav__search { flex: 1; max-width: 32rem; }
  .nav__search--mobile { display: none; }

  .nav__menu { display: flex; align-items: center; gap: var(--sp-5); flex: none; }
  .nav__links { display: flex; align-items: center; gap: var(--sp-5); list-style: none; margin: 0; padding: 0; }
  .nav__link { position: relative; text-decoration: none; color: var(--c-ink); font-weight: 600; font-size: var(--fs-350); padding: 0.4rem 0; white-space: nowrap; }
  .nav__link::after { content: ""; position: absolute; left: 0; right: 100%; bottom: -2px; height: 2px; background: var(--c-terracotta); border-radius: 2px; transition: right var(--dur) var(--ease); }
  .nav__link:hover { color: var(--c-terracotta-d); }
  .nav__link:hover::after, .nav__link.is-active::after { right: 0; }
  .nav__link.is-active { color: var(--c-terracotta-d); }

  .nav__upload { display: inline-flex; align-items: center; gap: 0.4rem; text-decoration: none; font-weight: 700; font-size: var(--fs-350); color: var(--c-terracotta-d); white-space: nowrap; }
  .nav__upload:hover { color: var(--c-terracotta); }

  .nav__toggle { display: none; place-items: center; width: 46px; height: 46px; background: var(--c-surface); color: var(--c-ink); border: 1px solid var(--c-cream-line); border-radius: 12px; cursor: pointer; margin-left: auto; }

  @media (max-width: 1040px) { .nav__search { display: none; } }
  @media (max-width: 900px) {
    .nav__toggle { display: grid; }
    .nav__menu {
      position: absolute; top: calc(100% + 1px); left: 0; right: 0;
      flex-direction: column; align-items: stretch; gap: var(--sp-4);
      padding: var(--sp-5); background: var(--c-paper);
      border-bottom: 1px solid var(--c-cream-line); box-shadow: var(--shadow-lg);
      transform: translateY(-12px); opacity: 0; pointer-events: none;
      transition: transform var(--dur) var(--ease), opacity var(--dur) var(--ease);
    }
    .nav__menu.is-open { transform: translateY(0); opacity: 1; pointer-events: auto; }
    .nav__search--mobile { display: block; }
    .nav__links { flex-direction: column; align-items: flex-start; gap: var(--sp-4); }
    .nav__link { font-size: var(--fs-500); }
    .nav__upload { font-size: var(--fs-500); }
    .nav__cta { justify-content: center; }
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('.nav__toggle');
  const menu = document.getElementById('nav-menu');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(!!open));
    toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
  });
</script>
