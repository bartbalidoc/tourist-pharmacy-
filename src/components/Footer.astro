---
import Icon from './Icon.astro';
import { SITE, WHATSAPP, OPERATOR, PHARMACY, PHARMACIST, waLink } from '../lib/site';
const year = 2026; // build-time constant
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <div class="footer__logo">
        <img class="footer__mark" src="/logo-mark.svg" alt="" width="34" height="34" /> Tourist Pharmacy
      </div>
      <p class="footer__desc">
        Operated by {OPERATOR.name}. A licensed, BPOM-compliant pharmacy service for
        English-speaking visitors and expats in Bali.
      </p>
      <a class="btn btn--whatsapp btn--sm footer__wa" href={waLink()} target="_blank" rel="noopener">
        <Icon name="whatsapp" /> {WHATSAPP.display}
      </a>
    </div>

    <nav class="footer__col" aria-label="Footer">
      <h4 class="footer__h">Explore</h4>
      <ul>
        <li><a href="/products">Products</a></li>
        <li><a href="/request">Request a medicine</a></li>
        <li><a href="/about">About Us</a></li>
        <li><a href="/booking">Get a Prescription</a></li>
        <li><a href={waLink()} target="_blank" rel="noopener">Contact</a></li>
      </ul>
    </nav>

    <nav class="footer__col" aria-label="Legal">
      <h4 class="footer__h">Legal</h4>
      <ul>
        <li><a href="/privacy">Privacy Policy</a></li>
        <li><a href="/terms">Terms of Use</a></li>
      </ul>
    </nav>

    <div class="footer__col footer__compliance">
      <h4 class="footer__h">Licensed &amp; Accountable</h4>
      <p>{PHARMACY.name}</p>
      <p>Izin Apotek No. {PHARMACY.license}</p>
      <p>Pharmacist: {PHARMACIST.name}</p>
      <p>NIB {OPERATOR.nib}</p>
    </div>
  </div>

  <div class="footer__bar">
    <div class="container footer__bar-inner">
      <p>© {year} {SITE.name} — {OPERATOR.name}. All rights reserved.</p>
      <p class="footer__note">
        Prescription-only (obat keras) medicines require a valid doctor's prescription.
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--c-paper-2);
    color: var(--c-ink-soft);
    border-top: 1px solid var(--c-cream-line);
    margin-top: var(--sp-9);
  }
  .footer__inner {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1.4fr;
    gap: var(--sp-6);
    padding-block: var(--sp-8) var(--sp-7);
  }
  .footer__logo {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-display);
    font-size: 1.35rem;
    color: var(--c-ink);
    margin-bottom: var(--sp-3);
  }
  .footer__mark { width: 34px; height: 34px; flex: none; }
  .footer__desc { color: var(--c-ink-soft); font-size: var(--fs-300); max-width: 32ch; margin-bottom: var(--sp-4); }
  .footer__wa { padding: 0.55em 1em; font-size: var(--fs-300); }

  .footer__h {
    color: var(--c-ink);
    font-family: var(--font-body);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: var(--fs-300);
    margin-bottom: var(--sp-3);
  }
  .footer__col ul { list-style: none; padding: 0; display: grid; gap: var(--sp-2); }
  .footer__col a { color: var(--c-ink-soft); text-decoration: none; }
  .footer__col a:hover { color: var(--c-terracotta-d); text-decoration: underline; }
  .footer__compliance p { color: var(--c-ink-faint); font-size: var(--fs-300); line-height: 1.45; }

  .footer__bar { border-top: 1px solid var(--c-cream-line); }
  .footer__bar-inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: var(--sp-3);
    padding-block: var(--sp-4);
    font-size: var(--fs-300);
    color: var(--c-ink-faint);
  }
  .footer__note { font-style: italic; }

  @media (max-width: 820px) {
    .footer__inner { grid-template-columns: 1fr 1fr; }
    .footer__brand { grid-column: 1 / -1; }
  }
  @media (max-width: 520px) {
    .footer__inner { grid-template-columns: 1fr; }
  }
</style>
