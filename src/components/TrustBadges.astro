---
import Icon from './Icon.astro';
import { TRUST_BADGES } from '../lib/site';
interface Props { compact?: boolean; }
const { compact = false } = Astro.props;
---
<div class:list={['trust', { 'trust--compact': compact }]}>
  {TRUST_BADGES.map((b) => (
    <div class="trust__item">
      <span class="trust__ic"><Icon name={b.icon} size="1.2rem" /></span>
      <div><strong>{b.label}</strong>{!compact && <span>{b.sub}</span>}</div>
    </div>
  ))}
</div>
<style>
  .trust { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--sp-4); }
  .trust__item { display: flex; align-items: center; gap: 0.7rem; }
  .trust__ic {
    flex: none; display: grid; place-items: center; width: 40px; height: 40px;
    border-radius: 11px; background: var(--c-clay-2); color: var(--c-terracotta-d);
  }
  .trust__item strong { display: block; font-size: var(--fs-350); color: var(--c-ink); line-height: 1.2; }
  .trust__item span { font-size: var(--fs-300); color: var(--c-ink-faint); }
  .trust--compact { grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: var(--sp-3); }
  @media (max-width: 820px) { .trust { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 460px) { .trust { grid-template-columns: 1fr; } }
</style>
