---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import { waLink } from '../lib/site';
---

<BaseLayout
  title="Page not found"
  description="The page you were looking for isn't here. Browse our medicines or get in touch."
>
  <section class="nf">
    <div class="container container-narrow nf__inner">
      <p class="nf__code" aria-hidden="true"><Icon name="cross" size="1.5rem" /> 404</p>
      <h1>We couldn't find that page</h1>
      <p class="nf__lede">
        The page may have moved, or the link might be slightly off. Let's get you back on track.
      </p>
      <div class="nf__cta">
        <a class="btn btn--primary" href="/products">Browse Products <Icon name="arrow-right" /></a>
        <a class="btn btn--ghost" href="/">Back to Home</a>
        <a class="btn btn--whatsapp" href={waLink()} target="_blank" rel="noopener"><Icon name="whatsapp" /> Ask us on WhatsApp</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .nf { padding-block: var(--sp-9); }
  .nf__inner { text-align: center; display: grid; gap: var(--sp-4); justify-items: center; }
  .nf__code { font-family: var(--font-display); color: var(--c-terracotta); font-size: var(--fs-700); font-weight: 700; }
  .nf h1 { font-size: var(--fs-800); }
  .nf__lede { color: var(--c-ink-soft); font-size: var(--fs-500); max-width: 44ch; }
  .nf__cta { display: flex; flex-wrap: wrap; gap: var(--sp-3); justify-content: center; margin-top: var(--sp-4); }
</style>
