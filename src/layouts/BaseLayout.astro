---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import StickyWhatsApp from '../components/StickyWhatsApp.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import { SITE, REVIEW_MODE } from '../lib/site';

interface Props {
  title: string;
  description?: string;
  /** Path to OG image relative to site root. Falls back to default. */
  ogImage?: string;
  /** Override the document <title> entirely (else `${title} — Tourist Pharmacy`). */
  fullTitle?: string;
  /** Pages with their own sticky bottom CTA (product pages) — lifts the floating
   *  WhatsApp button on mobile so it never covers the page's primary CTA. */
  stickyCta?: boolean;
}

const {
  title,
  description = SITE.description,
  ogImage = '/og-default.svg',
  fullTitle,
  stickyCta = false,
} = Astro.props;

const pageTitle = fullTitle ?? `${title} — ${SITE.name}`;
const canonical = new URL(Astro.url.pathname, SITE.url).href;
const ogUrl = new URL(ogImage, SITE.url).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={canonical} />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <!-- Fully indexable everywhere — never blocked from search. -->
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogUrl} />

    <meta name="theme-color" content="#244736" />

    <!-- Fonts: preconnect + display=swap so text paints immediately on slow Bali links. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
    />
  </head>
  <body class:list={{ 'has-sticky-cta': stickyCta }}>
    <a href="#main" class="skip-link">Skip to content</a>
    <Nav />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <StickyWhatsApp />
    {REVIEW_MODE && <FeedbackWidget />}

    <style>
      .skip-link {
        position: absolute;
        left: 50%;
        transform: translateX(-50%) translateY(-120%);
        top: 0;
        z-index: 100;
        background: var(--c-jungle);
        color: #fff;
        padding: 0.6rem 1rem;
        border-radius: 0 0 var(--radius-sm) var(--radius-sm);
        text-decoration: none;
        transition: transform var(--dur) var(--ease);
      }
      .skip-link:focus { transform: translateX(-50%) translateY(0); color: #fff; }
    </style>
  </body>
</html>
